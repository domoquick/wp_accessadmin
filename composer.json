{
    "name": "domoquick/wp-accessadmin",
    "description": "Corrige les URLs login/logout/admin lorsque WordPress est installé dans un sous-répertoire (pattern Bedrock).",
    "type": "wordpress-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Domoquick",
            "homepage": "https://github.com/domoquick"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Domoquick\\WpAccessAdmin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Domoquick\\WpAccessAdmin\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3.0"
        }
    }
}
